# Integration Framework Configuration

# Repository Discovery
GITHUB_TOKEN=your_github_token_here

# OpenCog Configuration
OPENCOG_ATOMSPACE_HOST=localhost
OPENCOG_ATOMSPACE_PORT=17001
OPENCOG_COGSERVER_HOST=localhost
OPENCOG_COGSERVER_PORT=17020

# ElizaOS Configuration
ELIZAOS_AGENT_MEMORY_PROVIDER=atomspace
ELIZAOS_ACTION_REGISTRY_TYPE=opencog
ELIZAOS_ENABLE_REASONING=true

# GnuCash Configuration
GNUCASH_FILE_PATH=/path/to/your/gnucash/file.gnucash
GNUCASH_BACKUP_ENABLED=true
GNUCASH_BACKUP_INTERVAL=3600

# Integration Settings
INTEGRATION_LOG_LEVEL=INFO
INTEGRATION_AUTO_SYNC=true
INTEGRATION_DISCOVERY_INTERVAL=86400